{
  "name": "minimum",
  "version": "2.0.0",
  "description": "MiMo Coding Experience Optimization - 针对MiMo模型的编码体验优化",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "minimum": "bin/minimum-ink.js",
    "minimum-ink": "bin/minimum-ink.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node node_modules/typescript/lib/tsc.js && node scripts/copy-assets.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "typecheck": "node node_modules/typescript/lib/tsc.js --noEmit"
  },
  "keywords": [
    "mimo",
    "coding",
    "ai",
    "agent",
    "optimization",
    "code-validation",
    "tool-repair"
  ],
  "author": "MiMo Team",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
