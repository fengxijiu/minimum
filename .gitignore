.minimum/
tasks/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local

# Comparison archives requested to stay out of git
CodeWhale-main.zip
DeepSeek-Reasonix-main.zip
*.zip

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

