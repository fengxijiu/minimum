{
  "mcpServers": [
    {
      "name": "minimum-github-writes",
      "transport": "stdio",
      "command": "minimum-mcp-server",
      "env": {
        "MINIMUM_PROJECT_ROOT": "${PWD}",
        "MINIMUM_MCP_GITHUB_ALLOW_WRITES": "true",
        "MINIMUM_MCP_GITHUB_ALLOWED_TOOLS": "github_create_pr_draft,github_comment_pr"
      },
      "tools": [
        "github_auth_status",
        "github_repo_info",
        "github_list_prs",
        "github_pr_view",
        "github_issue_view",
        "github_ci_status",
        "github_create_pr_draft",
        "github_comment_pr"
      ],
      "cacheTtlMs": 2000
    }
  ]
}
